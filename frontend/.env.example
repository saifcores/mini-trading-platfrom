# --- Option A: Vite dev proxy (recommended for local full-stack) ---
# 1. Start backend on port 8080 (see repo README).
# 2. Use defaults: frontend/.env.development sets VITE_DEV_PROXY_TARGET — no copy step required for dev.
# 3. Optional: override here or in .env.local
# VITE_DEV_PROXY_TARGET=http://localhost:8080

# --- Option B: Same-origin /api without explicit URL (e.g. nginx serves both) ---
# VITE_API_RELATIVE=1

# --- Option C: Call backend directly (CORS must allow the Vite origin — backend CorsConfig does) ---
# VITE_API_URL=http://localhost:8080
